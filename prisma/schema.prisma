generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model CurrencyRate {
  id           Int      @id(map: "PK_currency_rate_id") @default(autoincrement())
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  date         DateTime @db.Date
  rate         Decimal  @db.Decimal
  fromCurrency Currency @map("from_currency")
  toCurrency   Currency @map("to_currency")

  @@map("currency_rate")
}

model Item {
  id          Int       @id(map: "PK_item_id") @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  title       String    @db.VarChar(255)
  workspaceId Int       @map("workspace_id")
  itemTag     ItemTag[]
  payment     Payment[]
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_item_workspace_id_workspace_id")

  @@map("item")
}

model ItemTag {
  id        Int      @id(map: "PK_item_tag_id") @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  itemId    Int      @map("item_id")
  tagId     Int      @map("tag_id")
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_item_tag_item_id_item_id")
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_item_tag_tag_id_tag_id")

  @@unique([itemId, tagId], map: "UQ_item_tag_item_id_tag_id")
  @@map("item_tag")
}

model Payment {
  id        Int      @id(map: "PK_payment_id") @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  cost      Decimal  @db.Decimal
  itemId    Int      @map("item_id")
  date      DateTime @db.Date
  title     String?  @db.VarChar
  currency  Currency
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_payment_item_id_item_id")

  @@map("payment")
}

model Tag {
  id          Int       @id(map: "PK_tag_id") @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  title       String    @db.VarChar(100)
  color       String    @default("000000") @db.VarChar(6)
  itemTag     ItemTag[]
  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_tag_workspace_id_workspace_id")

  @@map("tag")
}

enum Currency {
  BYN
  USD
  EUR
}

model User {
  id                       Int                @id(map: "PK_user_id") @default(autoincrement())
  createdAt                DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                DateTime           @default(now()) @map("updated_at") @db.Timestamp(6)
  email                    String             @unique @db.VarChar(255)
  password                 String             @db.VarChar(72)
  name                     String             @db.VarChar(50)
  isBanned                 Boolean            @default(false) @map("is_banned")
  confirmEmailTempCode     String?            @map("confirm_email_temp_code")
  resetPasswordTempCode    String?            @map("reset_password_temp_code")
  workspaces               Workspace[]
  inviters                 Invite[]           @relation(name: "inviter")
  invitees                 Invite[]           @relation(name: "invitee")
  sourceContacts           Contact[]          @relation(name: "sourceUser")
  targetContacts           Contact[]          @relation(name: "targetUser")
  removedContacts          Contact[]          @relation(name: "removedByUser")
  sourceUserBlocks         UserBlock[]        @relation(name: "blocker")
  targetUserBlocks         UserBlock[]        @relation(name: "blocked")
  removedUserBlocks        UserBlock[]        @relation(name: "removedByUser")
  workspaceHistoryEntries  WorkspaceHistory[]
  permissions              UserPermission[]
  workspaceMemberships     WorkspaceMember[]
  sentWorkspaceInvites     WorkspaceInvite[]  @relation(name: "workspaceInviter")
  receivedWorkspaceInvites WorkspaceInvite[]  @relation(name: "workspaceInvitee")

  @@map("user")
}

enum Permission {
  USER_LIST
  USER_READ
  USER_UPDATE
  USER_DELETE
  USER_BAN
  USER_UNBAN
  WORKSPACE_CREATE
  WORKSPACE_READ
  WORKSPACE_UPDATE
  WORKSPACE_DELETE
  ITEM_READ
  ITEM_CREATE
  ITEM_UPDATE
  ITEM_DELETE
  TAG_CREATE
  TAG_UPDATE
  TAG_DELETE
  PAYMENT_READ
  PAYMENT_CREATE
  PAYMENT_UPDATE
  PAYMENT_DELETE
  CONTACT_DELETE
  INVITE_CREATE
  INVITE_ACCEPT
  INVITE_REJECT
  USER_BLOCK_CREATE
  USER_BLOCK_DELETE
  ITEM_TAG_MANAGE
  WORKSPACE_INVITE_CREATE
  WORKSPACE_INVITE_ACCEPT
  WORKSPACE_INVITE_REJECT
  WORKSPACE_MEMBER_REMOVE
  WORKSPACE_INVITE_USER
}

model UserPermission {
  userId      Int        @map("user_id")
  permission  Permission
  accessLevel Int        @default(1) @map("access_level")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_user_permission_user_id_user_id")

  @@id([userId, permission])
  @@map("user_permission")
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model WorkspaceMember {
  id          Int          @id(map: "PK_workspace_member_id") @default(autoincrement())
  workspaceId Int          @map("workspace_id")
  userId      Int          @map("user_id")
  permissions Permission[]
  joinedAt    DateTime     @default(now()) @map("joined_at") @db.Timestamp(6)
  leftAt      DateTime?    @map("left_at") @db.Timestamp(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_workspace_member_workspace_id_workspace_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_workspace_member_user_id_user_id")

  @@unique([workspaceId, userId], where: { leftAt: null }, map: "UQ_workspace_member_workspace_id_user_id")
  @@map("workspace_member")
}

model WorkspaceInvite {
  id          Int                   @id(map: "PK_workspace_invite_id") @default(autoincrement())
  workspaceId Int                   @map("workspace_id")
  inviterId   Int                   @map("inviter_id")
  inviteeId   Int                   @map("invitee_id")
  status      WorkspaceInviteStatus
  permissions Permission[]
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamp(6)
  reactedAt   DateTime?             @map("reacted_at") @db.Timestamp(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_workspace_invite_workspace_id_workspace_id")
  inviter   User      @relation(name: "workspaceInviter", fields: [inviterId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_workspace_invite_inviter_id_user_id")
  invitee   User      @relation(name: "workspaceInvitee", fields: [inviteeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_workspace_invite_invitee_id_user_id")

  @@unique([workspaceId, inviteeId], where: { reactedAt: null }, map: "UQ_workspace_invite_workspace_id_invitee_id")
  @@map("workspace_invite")
}

model Workspace {
  id              Int                @id(map: "PK_workspace_id") @default(autoincrement())
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime           @default(now()) @map("updated_at") @db.Timestamp(6)
  title           String             @db.VarChar(255)
  ownerId         Int                @map("owner_id")
  defaultCurrency Currency           @map("default_currency")
  items           Item[]
  tags            Tag[]
  historyEntries  WorkspaceHistory[]
  members         WorkspaceMember[]
  invites         WorkspaceInvite[]

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_workspace_owner_id_user_id")

  @@map("workspace")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Invite {
  id        Int          @id(map: "PK_invite_id") @default(autoincrement())
  inviterId Int          @map("inviter_id")
  inviteeId Int          @map("invitee_id")
  status    InviteStatus
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  reactedAt DateTime?    @map("reacted_at") @db.Timestamp(6)

  inviter  User      @relation(name: "inviter", fields: [inviterId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_invite_inviter_id_user_id")
  invitee  User      @relation(name: "invitee", fields: [inviteeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_invite_invitee_id_user_id")
  contacts Contact[]

  @@unique([inviterId, inviteeId], where: { reactedAt: null }, map: "UQ_invite_inviter_id_invitee_id")
  @@map("invite")
}

model Contact {
  id              Int       @id(map: "PK_contact_id") @default(autoincrement())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  sourceUserId    Int       @map("source_user_id")
  targetUserId    Int       @map("target_user_id")
  inviteId        Int       @map("invite_id")
  removedAt       DateTime? @map("removed_at") @db.Timestamp(6)
  removedByUserId Int?      @map("removed_by_user_id")

  sourceUser    User   @relation(name: "sourceUser", fields: [sourceUserId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_contact_source_user_id_user_id")
  targetUser    User   @relation(name: "targetUser", fields: [targetUserId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_contact_target_user_id_user_id")
  removedByUser User?  @relation(name: "removedByUser", fields: [removedByUserId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_contact_removed_by_user_id_user_id")
  invite        Invite @relation(fields: [inviteId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_contact_invite_id_invite_id")

  @@unique([sourceUserId, targetUserId], where: { removedAt: null }, map: "UQ_contact_inviter_id_invitee_id")
  @@map("contact")
}

model UserBlock {
  id              Int       @id(map: "PK_block_id") @default(autoincrement())
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  blockerId       Int       @map("blocker_id")
  blockedId       Int       @map("blocked_id")
  removedAt       DateTime? @map("removed_at") @db.Timestamp(6)
  removedByUserId Int?      @map("removed_by_user_id")

  blocker       User  @relation(name: "blocker", fields: [blockerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_user_block_blocker_id_user_id")
  blocked       User  @relation(name: "blocked", fields: [blockedId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_user_block_blocked_id_user_id")
  removedByUser User? @relation(name: "removedByUser", fields: [removedByUserId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_user_block_removed_by_user_id_user_id")

  @@unique([blockerId, blockedId], where: { removedAt: null }, map: "UQ_user_block_blocker_id_blocked_id")
  @@map("user_block")
}

enum WorkspaceHistoryAction {
  ITEM_CREATED
  ITEM_UPDATED
  ITEM_DELETED
  PAYMENT_CREATED
  PAYMENT_UPDATED
  PAYMENT_DELETED
  ITEM_TAG_ASSIGNED
  ITEM_TAG_UNASSIGNED
  TAG_CREATED
  TAG_UPDATED
  TAG_DELETED
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED
  ITEM_MERGED
  ITEM_EXTRACTED
  WORKSPACE_MEMBER_JOINED
  WORKSPACE_MEMBER_REMOVED
}

model WorkspaceHistory {
  id          Int                    @id(map: "PK_workspace_history_id") @default(autoincrement())
  workspaceId Int                    @map("workspace_id")
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_workspace_history_workspace_id_workspace_id")
  actorId     Int                    @map("actor_id")
  actor       User                   @relation(fields: [actorId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_workspace_history_actor_id_user_id")
  action      WorkspaceHistoryAction
  oldValue    Json?                  @map("old_value")
  newValue    Json?                  @map("new_value")
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("workspace_history")
}
