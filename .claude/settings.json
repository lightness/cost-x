{
  "enabledPlugins": {
    "commit-message@carlo-marketplace": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && npx biome check --write \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Sorting imports..."
          }
        ]
      }
    ]
  }
}
